rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin UID — full read access across all user data
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'gTcIsKmAyyWhQfg1eCAb3ZxKFqj2';
    }

    match /users/{userId}/{document=**} {
      // Users can read/write their own data; admin can read all
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Admin analytics — read-only for admin; written only by Cloud Functions (service account)
    match /admin/{document=**} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions write via service account, never from client
    }

    // Rate limit docs are written by Cloud Functions only
    match /rate_limits/{uid} {
      allow read, write: if false;
    }
  }
}
